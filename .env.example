# ── LiteLLM Proxy (injected by the evaluation platform) ─────────────────────
# API_BASE_URL: The API endpoint for the LLM (LiteLLM proxy URL).
API_BASE_URL=https://your-litellm-proxy.example.com/v1

# API_KEY: The injected LiteLLM key — REQUIRED when API_BASE_URL is set.
API_KEY=replace_with_injected_litellm_key

# MODEL_NAME: The model identifier to use for inference.
MODEL_NAME=gpt-4.1-mini

# HF_TOKEN: Your Hugging Face token (used as fallback API key).
HF_TOKEN=replace_with_your_hf_token

# ── Legacy / Optional fallbacks ──────────────────────────────────────────────
OPENAI_API_KEY=replace_with_your_openai_key
MODEL_BASE_URL=

# ── Environment server ───────────────────────────────────────────────────────
# Local environment API endpoint (used by inference.py to talk to the server)
ENV_BASE_URL=http://127.0.0.1:8000

# ── Agent behaviour ──────────────────────────────────────────────────────────
# Agent mode: rule | llm | hybrid (hybrid = LLM with rule-based fallback)
AGENT_MODE=hybrid