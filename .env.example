# Required for inference client model endpoint
# Prefer MODEL_BASE_URL (API_BASE_URL is kept for backward compatibility).
MODEL_BASE_URL=https://your-litellm-proxy.example.com/v1
API_BASE_URL=
MODEL_NAME=gemini-3-flash-preview
HF_TOKEN=replace_with_your_token

OPENAI_API_KEY=replace_with_your_token

# Local environment API endpoint
ENV_BASE_URL=http://127.0.0.1:8000

# Task selector (easy_fulfillment | medium_restock | hard_peak_season)
TASK_ID=easy_fulfillment

# Agent mode (rule | llm | hybrid)
AGENT_MODE=hybrid